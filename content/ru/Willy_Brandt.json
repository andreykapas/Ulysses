{
  "title": "Willy Brandt",
  "type": "poem",
  "date": "2026-06-22",
  "section": "lyrics",
  "text": [
    [
      "Я исследуваю жизнь...",
      "На лету, бегом!",
      "Мозг рожает эту мысль...",
      "Или Мысль его???"
    ],
    [
      "Восьмером косяк пингвинов.",
      "Всё по кругу и квадранту...",
      "Ребус умный, но наивный)",
      "Пётор пишет Вилли Брандту..."
    ],
    [
      "Друг мой Вилли, а скажи ка -",
      "Где восток с утра и осень?",
      "С кем ты рядом? Где улики?",
      "Вилли молча воздыхает..."
    ]
  ]
}
