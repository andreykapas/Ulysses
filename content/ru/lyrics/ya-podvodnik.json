{
  "title": "Я подводник",
  "type": "poem",
  "date": "2026-07-06",
  "section": "lyrics",
  "text": [
    [
      "нас в ряды поставят ровно...",
      "нас причешут и побреют...",
      "тех к козлам, а тех к коровам...",
      "те мычат, а эти блеют..."
    ],
    [
      "ну и что ж, не слушать Музу?!",
      "не дрожать??? не преклоняться???",
      "над ярмом... под томным грузом,",
      "я продолжу) я подводник)"
    ]
  ]
}
