{
  "title": "Разгонись и...",
  "type": "poem",
  "date": "2026-07-14",
  "section": "lyrics",
  "text": [
    [
      "Пубертатный период продуцирует поиск",
      "Восьмикратного смысла и валетной дуги",
      "Гуталин не фактичен иссечён будто волос",
      "Бюрократные соки разгонись и беги"
    ],
    [
      "Мокасины вассалов исчезают в закрепах",
      "Седовласый конвейер атрибутит конвой",
      "Магистраль топинамбур уступает дабстепу",
      "Фотография в профиль разгонись и постой"
    ],
    [
      "Беспокойство сомнений комисарных кумиров",
      "Междометий кустарных не приемлют ежи",
      "Опрометчиво скользко у подножья Памира",
      "Целомудренно слушай разгонись и лежи"
    ],
    [
      "Всё не так и не этак и не в глаз и не в бровь",
      "Овцы доят протезы солнце яркое блядь",
      "Жилы стынут от правды постулирует кровь",
      "Выйди с флагом на паперть разгонись и присядь"
    ],
    [
      "Камуфляжный куратор оперирует благом",
      "Барабанщик в экстазе отбивает набат",
      "Просветлённый сотрудник скорость меряет лагом",
      "Слушай всех осторожно разгонись и назад"
    ],
    [
      "Углеродно нейтральной оботри пилон смазкой",
      "Подорви все вулканы разогрей синий лёд",
      "Напиши анаграмы оберни лицо маской",
      "Разожги все костёры разгонись и вперёд"
    ]
  ]
}
