{
  "title": "Саша с Дантесом",
  "type": "poem",
  "date": "2026-07-23",
  "section": "lyrics",
  "text": [
    [
      "Имеющий ухо услышит",
      "Имеющего колесо.",
      "Умеющий брюхо напишет",
      "Умеющему в лицо."
    ],
    [
      "Описки, отписки, признанья...",
      "Встаёт, между прочим, Апрель)",
      "На Ясене ищет познанье...",
      "А Саша с Дантесом - дуэль."
    ]
  ]
}
