  "text": [
    [
      "запятые на бумаге...",
      "междуточие рефреном...",
      "ток легенды, мудрость саги...",
      "правым бортом, левым креном..."
    ],
    [
      "я не первый, я целован...",
      "я в ряду с Лукой и Ницше!",
      "я тоскою коронован...",
      "тише, миленький мой, тише)))"
    ]
  ]
}
