{
  "title": "Аз есмь никто",
  "type": "poem",
  "date": "2026-07-21",
  "section": "lyrics",
  "text": [
    [
      "Аз есмь никто!",
      "И гладки взятки)",
      "Жак Ив Кусто",
      "Играет в прятки)"
    ],
    [
      "Жан Жак Руссо...",
      "Бен Гур и ведьмы",
      "Ковбой с лассо...",
      "Пардон, под пледью)))"
    ],
    [
      "Поль Бельмондо",
      "Кусает жабры.",
      "За лесом лес...",
      "Всем вёдрам - швабры!"
    ],
    [
      "Крестьянам - крест!",
      "Рабочим - водку!",
      "Дающий перст",
      "Качает лодку..."
    ],
    [
      "Кого спросить?",
      "Кому ответить?",
      "Кому-то Пётр...",
      "Кому-то Петя..."
    ],
    [
      "Пускай его",
      "Не слышит инок,",
      "А я в Ленгово!",
      "Жмёт ботинок..."
    ]
  ]
}
